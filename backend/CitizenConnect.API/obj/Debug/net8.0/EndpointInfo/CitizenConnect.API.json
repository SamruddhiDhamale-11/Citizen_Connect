    "/api/Complaint/create": {
      "post": {
        "tags": [
          "Complaint"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "CitizenId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "WardId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "ComplaintCategoryId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "Title": {
                    "type": "string"
                  },
                  "Description": {
                    "type": "string"
                  },
                  "Address": {
                    "type": "string"
                  },
                  "Latitude": {
                    "type": "number",
                    "format": "double"
                  },
                  "Longitude": {
                    "type": "number",
                    "format": "double"
                  },
                  "Priority": {
                    "type": "string"
                  },
                  "IsAnonymous": {
                    "type": "boolean"
                  },
                  "Files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              },
              "encoding": {
                "CitizenId": {
                  "style": "form"
                },
                "WardId": {
                  "style": "form"
                },
                "ComplaintCategoryId": {
                  "style": "form"
                },
                "Title": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "Address": {
                  "style": "form"
                },
                "Latitude": {
                  "style": "form"
                },
                "Longitude": {
                  "style": "form"
                },
                "Priority": {
                  "style": "form"
                },
                "IsAnonymous": {
                  "style": "form"
                },
                "Files": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
